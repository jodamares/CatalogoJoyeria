// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MaterialType {
  ORO
  PLATA
  ACERO
  OTRO
}

enum GoldKarat {
  K10
  K14
  K18
  K24
}

enum ServiceQuoteStatus {
  PENDIENTE
  CONTACTADO
  CERRADO
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  CANCELADO
}

enum OrderPaymentMethod {
  TARJETA
  PAYPAL
  TRANSFERENCIA
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id             String       @id @default(cuid())
  name           String
  description    String
  imageUrl       String
  materialType   MaterialType
  karat          GoldKarat?
  weightGrams    Decimal      @db.Decimal(10, 3)
  laborCost      Decimal      @default(0) @db.Decimal(14, 2)
  marginCost     Decimal      @default(0) @db.Decimal(14, 2)
  fixedBasePrice Decimal?     @db.Decimal(14, 2)
  active         Boolean      @default(true)
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model GoldPriceCurrent {
  id           String    @id @default(cuid())
  karat        GoldKarat @unique
  pricePerGram Decimal   @db.Decimal(14, 2)
  source       String?
  updatedAt    DateTime  @updatedAt
}

model GoldPriceHistory {
  id           String    @id @default(cuid())
  karat        GoldKarat
  pricePerGram Decimal   @db.Decimal(14, 2)
  source       String?
  createdAt    DateTime  @default(now())
}

model Service {
  id          String         @id @default(cuid())
  name        String
  description String
  imageUrl    String?
  active      Boolean        @default(true)
  quotes      ServiceQuote[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ServiceQuote {
  id         String             @id @default(cuid())
  serviceId  String?
  service    Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  clientName String
  phone      String
  detail     String
  status     ServiceQuoteStatus @default(PENDIENTE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model SiteConfig {
  id        String   @id @default(cuid())
  logoUrl   String?
  storeName String   @default("Joyeria Premiun")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id            String             @id @default(cuid())
  userId        String?
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName  String
  customerEmail String
  phone         String
  address       String
  city          String
  postalCode    String
  paymentMethod OrderPaymentMethod
  status        OrderStatus        @default(PENDIENTE)
  currency      String             @default("COP")
  total         Decimal            @db.Decimal(14, 2)
  notes         String?
  items         Json
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}
